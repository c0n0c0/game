<!DOCTYPE html>
<html lang="ja">
<head>
<meta charset="UTF-8">
<title>マウス操作ゲーム</title>

<style>
body{
    font-family:sans-serif;
    text-align:center;
    background:#eef7ff;
}

h1{
    margin-top:20px;
}

.area{
    margin:40px auto;
}

/* フタ */

.gacha{
    width:200px;
    margin:20px auto;
    position:relative;
}

.lid{
    width:200px;
    height:60px;
    background:#ff6b6b;
    border-radius:10px 10px 0 0;
    position:absolute;
    transform-origin:left;
    transition:0.6s;
    cursor:pointer;
}

.lid.open{
    transform:rotate(-120deg);
}

.box{
    width:200px;
    height:120px;
    background:#ffd43b;
    border-radius:0 0 10px 10px;
    margin-top:60px;
    display:flex;
    align-items:center;
    justify-content:center;
    font-size:22px;
}
