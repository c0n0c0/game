<!DOCTYPE html>
<html lang="ja">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>リズム・タイミング・ゲーム</title>
    <style>
        :root {
            --bg-color: #1a1a2e;
            --target-color: #e94560;
            --ring-color: #0f3460;
            --text-color: #ffffff;
        }

        body {
            margin: 0;
            padding: 0;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            height: 100vh;
            background-color: var(--bg-color);
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            color: var(--text-color);
            overflow: hidden;
            user-select: none;
        }

        #game-container {
            position: relative;
            width: 300px;
            height: 300px;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        /* ターゲット（中心のボタン） */
        #target {
            width: 80px;
            height: 80px;
            background-color: var(--target-color);
            border-radius: 50%;
            cursor: pointer;
            z-index: 10;
            box-shadow: 0 0 20px rgba(233, 69, 96, 0.5);
            transition: transform 0.1s;
        }

        #target:active {
            transform: scale(0.9);
        }

        /* 収束するリング */
        .ring {
            position: absolute;
            border: 4px solid var(--text-color);
            border-radius: 50%;
            pointer-events: none;
            opacity: 0.6;
        }

        /* スコアとメッセージ */
        #ui {
            text-align: center;
            margin-bottom: 20px;
        }

        #score {
            font-size: 2rem;
            font-weight: bold;
            margin: 0;
        }

        #message {
            height: 1.5rem;
            font-size: 1.2rem;
            color: #4ecca3;
            margin-top: 10px;
        }

        .instructions {
            margin-top: 30px;
            font-size: 0.9rem;
            opacity: 0.7;
        }
    </style>
</head>
<body>

    <div id="ui">
        <p id="score">Score: 0</p>
        <div id="message">READY?</div>
    </div>

    <div id="game-container">
        <div id="target"></div>
        </div>

    <div class="instructions">
        白い輪っかが赤い円に重なる瞬間にクリック！
    </div>

    <script>
        const target = document.getElementById('target');
        const scoreDisplay = document.getElementById('score');
        const messageDisplay = document.getElementById('message');
        const container = document.getElementById('game-container');

        let score = 0;
        let activeRing = null;
        let ringScale = 3.0; // リングの初期サイズ（3倍）
        let gameLoop = null;
        const shrinkSpeed = 0.025; // 輪っかが縮まる速度

        // ゲームループの開始
        function startRing() {
            ringScale = 3.0;
            const ring = document.createElement('div');
            ring.className = 'ring';
            container.appendChild(ring);
            activeRing = ring;

            function animate() {
                if (!activeRing) return;

                ringScale -= shrinkSpeed;
                
                // リングのサイズ更新
                const size = 80 * ringScale;
                activeRing.style.width = size + 'px';
                activeRing.style.height = size + 'px';

                // 見逃した場合
                if (ringScale <= 0.5) {
                    updateMessage("MISS...", "#e94560");
                    resetRing();
                    score = Math.max(0, score - 5);
                    updateScore();
                    setTimeout(startRing, 1000);
                } else {
                    gameLoop = requestAnimationFrame(animate);
                }
            }
            gameLoop = requestAnimationFrame(animate);
        }

        // 判定処理
        function checkTiming() {
            if (!activeRing) return;

            cancelAnimationFrame(gameLoop);
            
            // 判定（1.0がジャストサイズ）
            const diff = Math.abs(ringScale - 1.0);
            
            if (diff < 0.1) {
                updateMessage("PERFECT!!", "#4ecca3");
                score += 10;
            } else if (diff < 0.25) {
                updateMessage("GOOD", "#f7d794");
                score += 5;
            } else {
                updateMessage("TOO EARLY", "#636e72");
                score = Math.max(0, score - 2);
            }

            updateScore();
            resetRing();
            
            // 次のリングまで少し待機
            setTimeout(startRing, 800);
        }

        function resetRing() {
            if (activeRing) {
                activeRing.remove();
                activeRing = null;
            }
        }

        function updateScore() {
            scoreDisplay.innerText = `Score: ${score}`;
        }

        function updateMessage(text, color) {
            messageDisplay.innerText = text;
            messageDisplay.style.color = color;
        }

        // イベントリスナー
        target.addEventListener('mousedown', (e) => {
            e.preventDefault();
            checkTiming();
        });

        // スペースキーでも操作可能に
        window.addEventListener('keydown', (e) => {
            if (e.code === 'Space') {
                checkTiming();
            }
        });

        // 起動
        setTimeout(startRing, 1000);
    </script>
</body>
</html>
