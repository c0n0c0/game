<!DOCTYPE html>

<html lang="ja">
<head>
<meta charset="UTF-8">
<title>矢印キーゲーム</title>

<style>
body{
font-family:sans-serif;
text-align:center;
background:#eef7ff;
}

h1{
margin-top:20px;
}

.area{
margin:40px auto;
}

/* フタ */

.gacha{
width:220px;
margin:20px auto;
position:relative;
}

.lid{
width:220px;
height:60px;
background:#ff6b6b;
border-radius:10px 10px 0 0;
position:absolute;
top:0;
left:0;
transform-origin:left bottom;
}

.box{
width:220px;
height:130px;
background:#ffd43b;
border-radius:0 0 10px 10px;
margin-top:60px;
display:flex;
align-items:center;
justify-content:center;
font-size:22px;
}

/* チャック */

.bag{
width:220px;
height:220px;
background:#74c0fc;
border-radius:12px;
margin:20px auto;
position:relative;
}

.teeth{
position:absolute;
left:107px;
top:10px;
width:6px;
height:200px;
background:repeating-linear-gradient(
to bottom,
#495057 0px,
#495057 6px,
#adb5bd 6px,
#adb5bd 12px
);
}

.openArea{
position:absolute;
top:0;
left:0;
width:100%;
height:0;
background:white;
}

.slider{
width:40px;
height:40px;
background:#343a40;
border-radius:50%;
position:absolute;
left:90px;
top:10px;
}

.result{
font-size:22px;
margin-top:10px;
}
</style>

</head>

<body>

<h1>🎮 矢印キーゲーム</h1>
<p>左右キー → フタ　／　上下キー → チャック</p>

<div class="area">
<h2>フタ</h2>

<div class="gacha">
<div class="lid" id="lid"></div>
<div class="box" id="lidResult">？</div>
</div>

</div>

<div class="area">
<h2>チャック</h2>

<div class="bag">
<div class="openArea" id="openArea"></div>
<div class="teeth"></div>
<div class="slider" id="slider"></div>
</div>

<div class="result" id="zipResult">？</div>

</div>

<script>

const items=[
"大当たり🎉",
"レア⭐",
"当たり🙂",
"普通",
"はずれ😢"
];

function randomItem(){
return items[Math.floor(Math.random()*items.length)];
}

/* フタ */

let angle=0;
const lid=document.getElementById("lid");
const lidResult=document.getElementById("lidResult");

/* チャック */

let zip=10;
const slider=document.getElementById("slider");
const openArea=document.getElementById("openArea");
const zipResult=document.getElementById("zipResult");

document.addEventListener("keydown",(e)=>{

/* フタ */

if(e.key==="ArrowRight"){
angle+=10;
}

if(e.key==="ArrowLeft"){
angle-=10;
}

if(angle<0)angle=0;
if(angle>120)angle=120;

lid.style.transform="rotate("+(-angle)+"deg)";

if(angle>100){
lidResult.textContent=randomItem();
}

/* チャック */

if(e.key==="ArrowDown"){
zip+=10;
}

if(e.key==="ArrowUp"){
zip-=10;
}

if(zip<10)zip=10;
if(zip>170)zip=170;

slider.style.top=zip+"px";
openArea.style.height=zip+"px";

if(zip>160){
zipResult.textContent=randomItem();
}

});

</script>

</body>
</html>
