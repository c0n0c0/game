<!DOCTYPE html>
<html lang="ja">
<head>
<meta charset="UTF-8">
<title>フタ＆チャックゲーム</title>

<style>
body{
    font-family:sans-serif;
    text-align:center;
    background:#eef7ff;
}

h1{
    margin-top:20px;
}

.area{
    margin:40px auto;
}

/* フタ */

.gacha{
    width:220px;
    margin:20px auto;
    position:relative;
}

.lid{
    width:220px;
    height:60px;
    background:#ff6b6b;
    border-radius:10px 10px 0 0;
    position:absolute;
    top:0;
    left:0;
    transform-origin:left bottom;
    cursor:pointer;
}

.box{
    width:220px;
    height:130px;
    background:#ffd43b;
    border-radius:0 0 10px 10px;
    margin-top:60px;
    display:flex;
    align-items:center;
    justify-content:center;
    font-size:22px;
}

/* チャック */

.bag{
    width:220px;
    height:220px;
    background:#74c0fc;
    border-radius:12px;
    margin:20px auto;
    position:relative;
}

.zipline{
    width:6px;
    height:200px;
    background:#495057;
    position:absolute;
    left:107px;
    top:10px;
}

.slider{
    width:40px;
    height:40px;
    background:#343a40;
    border-radius:50%;
    position:absolute;
    left:90px;
    top:10px;
    cursor:pointer;
}

.result{
    font-size:22px;
    margin-top:10px;
}
</style>
</head>

<body>

<h1>🖱️ フタ＆チャックゲーム</h1>

<div class="area">
<h2>フタをドラッグして開ける</h2>

<div class="gacha">
<div class="lid" id="lid"></div>
<div class="box" id="lidResult">？</div>
</div>

</div>

<div class="area">
<h2>チャックをドラッグ</h2>

<div class="bag">
<div class="zipline"></div>
<div class="slider" id="slider"></div>
</div>

<div class="result" id="zipResult">？</div>
</div>

<script>

const items=[
"大当たり🎉",
"レア⭐",
"当たり",
"普通🙂",
"はずれ😢"
];

function randomItem(){
return items[Math.floor(Math.random()*items.length)];
}

/* フタドラッグ */

const lid=document.getElementById("lid");
const lidResult=document.getElementById("lidResult");

let lidDragging=false;

lid.addEventListener("mousedown",()=>{
lidDragging=true;
});

document.addEventListener("mouseup",()=>{
lidDragging=false;
});

document.addEventListener("mousemove",(e)=>{

if(!lidDragging)return;

let gacha=document.querySelector(".gacha");
let rect=gacha.getBoundingClientRect();

let x=e.clientX-rect.left;

let angle=x/220*120;

if(angle>120)angle=120;
if(angle<0)angle=0;

lid.style.transform="rotate("+(-angle)+"deg)";

if(angle>100){
lidResult.textContent=randomItem();
}

});

/* チャックドラッグ */

const slider=document.getElementById("slider");
const zipResult=document.getElementById("zipResult");

let dragging=false;

slider.addEventListener("mousedown",()=>{
dragging=true;
});

document.addEventListener("mouseup",()=>{
dragging=false;
});

document.addEventListener("mousemove",(e)=>{

if(!dragging)return;

let bag=document.querySelector(".bag");
let rect=bag.getBoundingClientRect();

let y=e.clientY-rect.top-20;

if(y<10)y=10;
if(y>170)y=170;

slider.style.top=y+"px";

if(y>160){
zipResult.textContent=randomItem();
}

});

</script>

</body>
</html>
